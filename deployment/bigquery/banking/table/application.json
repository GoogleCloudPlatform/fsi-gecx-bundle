  },
  {
    "name": "product_type",
    "type": "STRING",
    "mode": "NULLABLE",
    "description": "Specific type of product within the category"
  },
  {
    "name": "requested_amount",
    "type": "NUMERIC",
    "mode": "NULLABLE",
    "description": "Requested amount for the product"
  },
  {
    "name": "application_status",
    "type": "STRING",
    "mode": "NULLABLE",
    "description": "Current status of the application"
  },
  {
    "name": "assigned_officer_id",
    "type": "STRING",
    "mode": "NULLABLE",
    "description": "Associated bank officer identifier"
  },
  {
    "name": "started_at",
    "type": "TIMESTAMP",
    "mode": "NULLABLE",

[
  {
    "name": "application_id",
    "type": "STRING",
    "mode": "REQUIRED",
    "description": "Unique identifier for the product application"
  },
  {
    "name": "user_id",
    "type": "STRING",
    "mode": "REQUIRED",
    "description": "Associated user identifier"
  },
  {
    "name": "product_category",
    "type": "STRING",
    "mode": "NULLABLE",
